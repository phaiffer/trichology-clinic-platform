SERVER_PORT=8080
DB_URL=jdbc:postgresql://localhost:5432/trichology_clinic
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DRIVER_CLASS_NAME=org.postgresql.Driver
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_SECURITY_PERMIT_ALL=true
APP_MEDIA_PATIENT_PHOTO_STORAGE_ROOT=./storage/patient-photos
APP_MEDIA_MAX_FILE_SIZE_BYTES=5242880
APP_MEDIA_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp
APP_MEDIA_MULTIPART_MAX_FILE_SIZE=5MB
APP_MEDIA_MULTIPART_MAX_REQUEST_SIZE=25MB
APP_REPORT_STORAGE_ROOT=./storage/reports
APP_REPORT_CLINIC_TITLE=Phaiffer Tech Trichology Clinic
APP_SCORING_MODERATE_THRESHOLD=10
APP_SCORING_HIGH_THRESHOLD=20
